{
  "manifest_version": 3,
  "name": "Focus",
  "version": "1.0.0",
  "description": "Maintain focus while reading by easily looking up word meanings.",
  "permissions": ["storage", "activeTab", "scripting", "unlimitedStorage"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "index.html",
    "default_title": "Focus Extension"
  }
}
